#!/usr/bin/env node
import { MemoOptions } from "../lib/memo_options.js";
import { MemoApp } from "../lib/memo_app.js";
import { MemoView } from "../lib/memo_view.js";

const options = new MemoOptions();
const app = await MemoApp.load();
const view = new MemoView(app);

if (options.isList()) {
  view.list();
} else if (options.isReference()) {
  await view.reference();
} else if (options.isDelete()) {
  await view.delete();
} else {
  process.stdin.setEncoding("utf8");
  let content = "";

  process.stdin
    .on("data", (chunk) => (content += chunk))
    .on("end", async () => {
      try {
        await app.add(content);
      } catch {
        console.error("Failed to add the memo.");
      }
    });
}
