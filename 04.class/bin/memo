#!/usr/bin/env node
import { MemoApp } from "../lib/memo_app.js";
import { MemoFormat } from "../lib/memo_format.js";
import { MemoOption } from "../lib/memo_option.js";

const option = new MemoOption();
const memoApp = await MemoApp.load();
const format = new MemoFormat(memoApp);

if (option.hasList()) {
  format.list();
} else if (option.hasReference()) {
  format.reference();
} else if (option.hasDelete()) {
  format.delete();
} else {
  process.stdin.setEncoding("utf8");
  let input = "";

  process.stdin
    .on("data", (chunk) => (input += chunk))
    .on("end", async () => {
      try {
        await memoApp.save(input);
      } catch (err) {
        console.error("メモの保存に失敗しました。");
      }
    });
}
