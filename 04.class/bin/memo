#!/usr/bin/env node
import { Command } from "commander";
import { MemoApp } from "../lib/memo_app.js";
import { MemoFormat } from "../lib/memo_format.js";

const program = new Command();
program.option("-l, --list", "list of memos");
program.parse();
const options = program.opts();
const memoApp = await MemoApp.load();

if (options.list) {
  const memoFormat = new MemoFormat(memoApp);
  memoFormat.list();
} else {
  process.stdin.setEncoding("utf8");
  let input = "";

  process.stdin
    .on("data", (chunk) => (input += chunk))
    .on("end", async () => {
      try {
        await memoApp.save(input);
      } catch (err) {
        console.error("メモの保存に失敗しました。");
      }
    });
}
