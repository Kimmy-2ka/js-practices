#!/usr/bin/env node
import { MemoOptions } from "../lib/memo_options.js";
import { MemoApp } from "../lib/memo_app.js";
import { MemoView } from "../lib/memo_view.js";

const options = new MemoOptions();
const memoApp = await MemoApp.load();
const view = new MemoView(memoApp);

if (options.hasList()) {
  view.list();
} else if (options.hasReference()) {
  view.reference();
} else if (options.hasDelete()) {
  view.delete();
} else {
  process.stdin.setEncoding("utf8");
  let input = "";

  process.stdin
    .on("data", (chunk) => (input += chunk))
    .on("end", async () => {
      try {
        await memoApp.add(input);
      } catch {
        console.error("Failed to add the memo.");
      }
    });
}
